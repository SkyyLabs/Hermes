# Copy to .env for local overrides.
LOCAL_MAC_AGENT_APP__NAME=LocalMacAgent
LOCAL_MAC_AGENT_LOGGING__LEVEL=INFO
LOCAL_MAC_AGENT_MODEL__PROVIDER=ollama
LOCAL_MAC_AGENT_MODEL__MODEL_NAME=gemma3
LOCAL_MAC_AGENT_MODEL__BASE_URL=http://127.0.0.1:11434
LOCAL_MAC_AGENT_MODEL__LOCAL_ONLY=true
LOCAL_MAC_AGENT_SAFETY__CLOUD_APIS_ENABLED=false
LOCAL_MAC_AGENT_VOICE__WAKE_WORD=hey_mycroft
LOCAL_MAC_AGENT_VOICE__WHISPER_MODEL=base.en
LOCAL_MAC_AGENT_VOICE__ACTIVE_LISTENING_SECONDS=4.0
